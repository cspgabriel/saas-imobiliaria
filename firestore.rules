rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global lock
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function getUserProfile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isUserAgency(agencyId) { return getUserProfile().agencyId == agencyId; }
    function hasRole(agencyId, role) { return isUserAgency(agencyId) && getUserProfile().role == role; }
    function isAgencyAdmin(agencyId) { return hasRole(agencyId, 'ADMIN'); }
    function isAgencyMember(agencyId) { return isUserAgency(agencyId); }
    
    // Agencies
    match /agencies/{agencyId} {
      // Anyone can read agency data (needed to load the site via domain)
      allow read: if true;
      // SECURITY: demo writes now require auth (was anonymous). TODO: move demo seeding to Cloud Function.
      allow write: if isSignedIn() && agencyId == 'demo';
      allow create: if isSignedIn() && request.resource.data.keys().hasAll(['name', 'subdomain', 'createdAt', 'ownerId']) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAgencyAdmin(agencyId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'customDomain', 'plan']);
    }

    // Users
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isSignedIn() && request.auth.uid == userId;
      // Admins can read users in their agency
      allow read, list: if isSignedIn() && isAgencyAdmin(resource.data.agencyId);
      // SECURITY FIX: previous rule forced role=='ADMIN' on every signup (privilege escalation).
      // Transitional: allow role in ['ADMIN','MEMBER'] only on create (self-registration of first
      // agency owner needs ADMIN). Update path forbids self-promotion (only admins can change role).
      // TODO: replace with Cloud Function + custom claim. First user of an agencyId should get
      // ADMIN via server-side check (Firestore rules can't efficiently query siblings).
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['email', 'role', 'agencyId', 'createdAt'])
        && request.resource.data.role in ['ADMIN', 'MEMBER'];
      // SECURITY: only admins of the same agency can update role/name. User cannot promote self.
      allow update: if isSignedIn() && isAgencyAdmin(resource.data.agencyId) && request.auth.uid != userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'name']);
      // Self-update of name only (not role)
      allow update: if isSignedIn() && request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name']);
    }

    // Properties
    match /agencies/{agencyId}/properties/{propertyId} {
      // Public read for properties of the agency
      allow read: if true;
      // SECURITY: demo writes require auth now (was anonymous wildcard). TODO: Cloud Function seed.
      allow write: if isSignedIn() && agencyId == 'demo';
      allow create: if isAgencyMember(agencyId) && request.resource.data.keys().hasAll(['title', 'price', 'type', 'status', 'city', 'bedrooms', 'bathrooms', 'area', 'createdAt']);
      allow update: if isAgencyMember(agencyId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'description', 'price', 'type', 'status', 'city', 'neighborhood', 'bedrooms', 'bathrooms', 'area', 'imageUrl', 'views', 'updatedAt']);
      allow delete: if isAgencyAdmin(agencyId);
    }

    // Leads
    match /agencies/{agencyId}/leads/{leadId} {
      // SECURITY: previously unauthenticated lead create — open to spam/abuse.
      // TODO: migrate public lead capture to Cloud Function + reCAPTCHA / App Check.
      // Transitional hardening: enforce strict shape and field whitelist to limit abuse surface.
      // Public landing-page submissions still allowed (no auth) but constrained.
      allow create: if request.resource.data.keys().hasAll(['name', 'status', 'createdAt'])
        && request.resource.data.keys().hasOnly(['name', 'status', 'createdAt', 'email', 'phone', 'message', 'propertyId', 'source'])
        && request.resource.data.size() < 20
        && request.resource.data.status == 'NEW'
        && request.resource.data.name is string && request.resource.data.name.size() < 200;
      // Read, update, delete only by agency members (demo still readable for showcase)
      allow read, list: if isAgencyMember(agencyId) || agencyId == 'demo';
      allow write: if isAgencyMember(agencyId) || (isSignedIn() && agencyId == 'demo');
      
      // Interactions
      match /interactions/{interactionId} {
        allow read, list, write: if isAgencyMember(agencyId) || (isSignedIn() && agencyId == 'demo');
      }
    }

    // Analytics
    match /agencies/{agencyId}/analytics/{hitId} {
      allow create: if request.resource.data.keys().hasAll(['path', 'timestamp']);
      allow read, list: if isAgencyAdmin(agencyId);
    }
  }
}
